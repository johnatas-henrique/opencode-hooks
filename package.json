{
  "name": "opencode-hooks",
  "version": "0.2.0",
  "description": "TypeScript plugin system for OpenCode AI providing event-driven hooks",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnatas-henrique/opencode-hooks.git"
  },
  "homepage": "https://github.com/johnatas-henrique/opencode-hooks#readme",
  "bugs": {
    "url": "https://github.com/johnatas-henrique/opencode-hooks/issues"
  },
  "scripts": {
    "start": "node .",
    "build": "tsc",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:e2e": "bash test/e2e/session-lifecycle.sh",
    "test": "npm run test:unit",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "coverage:report": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --coverageReporters=text-summary",
    "lint": "eslint \"**/*.ts\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"coverage/**\"",
    "lint:fix": "eslint \"**/*.ts\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"coverage/**\" --fix",
    "format": "prettier --write \"**/*.ts\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.ts\" --ignore-path .gitignore"
  },
  "keywords": [
    "opencode",
    "opencode-hooks",
    "plugin",
    "events",
    "automation",
    "typescript"
  ],
  "author": {
    "email": "johnatas.henrique@gmail.com",
    "name": "Johnatas Henrique"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.5",
    "@opencode-ai/sdk": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@trickfilm400/eslint-shared-config": "^0.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "files": [
    "dist",
    "typings"
  ],
  "typings": "types/index.d.ts"
}
