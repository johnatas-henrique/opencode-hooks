{
  "name": "opencode-hooks",
  "version": "0.4.1",
  "description": "TypeScript plugin system for OpenCode AI providing event-driven hooks",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node .",
    "build": "tsc",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathIgnorePatterns='test/integration|test/unit/benchmark' --passWithNoTests",
    "test:benchmark": "NODE_OPTIONS='--experimental-vm-modules' jest test/unit/benchmark --passWithNoTests",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest test/integration --passWithNoTests",
    "test:e2e": "bash test/e2e/session-lifecycle.sh && bash test/e2e/tool-execution.sh",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:cov": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "coverage:report": "NODE_OPTIONS='--experimental-vm-modules' jest --colors --coverage --coverageReporters=text-summary --coverageReporters=html 2>&1 | grep -v 'PASS '",
    "lint": "eslint \"**/*.ts\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"coverage/**\"",
    "lint:fix": "eslint \"**/*.ts\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"coverage/**\" --fix",
    "format": "prettier --write \"**/*.ts\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.ts\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "keywords": [
    "opencode",
    "opencode-hooks",
    "plugin",
    "events",
    "automation",
    "typescript"
  ],
  "author": {
    "email": "johnatas.henrique@gmail.com",
    "name": "Johnatas Henrique"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.3.5",
    "@opencode-ai/sdk": "^1.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,ts,md,json}": [
      "prettier --write"
    ]
  }
}
