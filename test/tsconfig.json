{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "outDir": "./dist-test",
    "rootDir": "..",
    "baseUrl": "..",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitThis": false,
    "declaration": false,
    "removeComments": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["node"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["./**/*.ts", "../.opencode/**/*.ts", "../src/**/*.ts"],
  "exclude": ["./dist-test", "../node_modules", "../dist"]
}
